{
    // -------------------------------------------------------------------------
    // Global configuration
    // -------------------------------------------------------------------------

    "layer": "top",
    "position": "top",
    "height": 45,
    "margin-left": 20,
    "margin-right": 10,
    "modules-left": [
        "custom/arch",
	      "group/launch",
        "hyprland/workspaces",
        "hyprland/window"
            ],
    //"modules-center": [
    //],
    "modules-right": [
        "group/tray-drawer",
        "hyprland/language",
        "wireplumber",
	      "group/indicators",
        "group/hardware",
        "clock",
        "custom/power"
            ],

    // -------------------------------------------------------------------------
    // Module Groups
    // -------------------------------------------------------------------------

"group/launch": {
  "orientation": "inherit",
    "modules": [
       "custom/terminal",
       "custom/browser",
       "custom/launcher",
       "custom/filemanager"
    ],
  },

"group/hardware": {
	"orientation": "inherit",
		"modules": [
			"memory",
			"cpu",
			"disk"
		]
	},

"group/indicators":{
	"orientation": "inherit",
    "modules": [
	   "bluetooth",
     "network",
	   "backlight",
     "battery"
	     ]
	},

 "group/tray-drawer":{
  "orientation": "inherit",
  "drawer": {
        "transition-duration": 500,
        "children-class": "not-power",
        "transition-left-to-right": false,
        "click-to-reveal": true
    },
    "modules": [
       "custom/hide-tray", 
       "tray"
    ],
  },

    // -------------------------------------------------------------------------
    // Modules
    // -------------------------------------------------------------------------

"hyprland/language": {
    "format": "ΎΗτ {}",
    "format-en": "en",
    "format-ru": "ru",
    "keyboard-name": "at-translated-set-2-keyboard",
    "on-click": "hyprctl switchxkblayout at-translated-set-2-keyboard next"
},

"bluetooth": {
	// "controller": "controller1", // specify the alias of the controller if there are more than 1 on the system
  	"format": "≤░Γψ",
	  "format-disabled": "", // an empty format will hide the module
  	"format-connected": "ΎΛΥ",
  	"tooltip-format": "{controller_alias}\t{controller_address}",
  	"tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
  	"tooltip-format-enumerate-connected": "{device_alias}\t{device_address}"
},

"disk": {
    "interval": 5,
    "format": " ΎΒ╝",
    "path": "/",
    "states": {
        "half": 50,
        "three-quarters": 75,
        "full": 90
    },
},

"backlight": {
    "device": "intel_backlight",
    "format": "{icon}",
    "format-icons": ["ΌΟΞ ", "ΌΠΥ ", "ΌΠΣ ", "ΌΠΠ ", "ΌΠΟ ", "ΌΠΞ ", "ΌΠΛ ", "ΌΠΙ ", "ΌΟδ "],
    "states": {
       "max": 100,
       "medium": 60
},
    "tooltip": true,
    "tooltip-format": "{percent}%"
},

"battery": {
        "interval": 10,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "≤▒ΡΜ{icon}", // Icon: bolt
        "format-discharging": "{icon}",
        "format-full": "≤░ΓΕ",
        "format-icons": [ "≤░Β║", "≤░Β╗", "≤░Β╝", "≤░Β╜", "≤░Β╛", "≤░Β┐", "≤░ΓΑ", "≤░ΓΒ", "≤░ΓΓ", "≤░Β╣" ],
        "tooltip": true,
        "tooltip-format": "{capacity}%, {timeTo}"
    },

"clock": {
        "interval": 1,
        "format": "ΎΑΩ {:%H:%M}",
        "format-alt": "ΎΒ│ {:L%a %d %b}", // Icon: calendar-alt 
        "format-alt-click": "click-left",
        "tooltip": true,
       "tooltip-format": "<tt><small>{calendar}</small></tt>",
       "calendar": {
         "mode"          : "month",
         "mode-mon-col"  : 3,
         "weeks-pos"     : "right",
         "on-scroll"     : 1,
         "format": {
         "months":     "<span color='#cdd6f4'><b>{}</b></span>",
         "days":       "<span color='#b4befe'><b>{}</b></span>",
         "weeks":      "<span color='#a6e3a1'><b>W{}</b></span>",
         "weekdays":   "<span color='#fab387'><b>{}</b></span>",
         "today":      "<span color='#f38ba8'><b><u>{}</u></b></span>"
          }
    },
        "actions":  {
         "on-click-right": "mode"
          }
    
    },

"cpu": {
        "interval": 5,
        "format": "ΎΜδ", // Icon: microchip
        "states": {
          "loaded": 40,
          "warning": 70,
          "critical": 90
        }
    },

"memory": {
        "interval": 5,
        "format": "ΎΦ╕ ", // Icon: memory
        "states": {
          "loaded": 40,
          "warning": 70,
          "critical": 90
        },
       "tooltip":true,
       "tooltip-format": "{used:0.1f}GiB used ({percentage}%)"
    },

"network": {
        "interval": 5,
        "format-wifi": "ΎΘτ", // Icon: wifi
        "format-ethernet": "Ό╝Κ", // Icon: ethernet
        "format-disconnected": "έγι",
        "tooltip-format": "{ifname}:{essid} {ipaddr}"
    },

"hyprland/window": {
        "format": "ΎΒξ"
    },

"hyprland/workspaces": {
        "all-outputs": false,
        "disable-scroll": true,
        "format": "{name}"
    },

"tray": {
        "icon-size": 20,
        "spacing": 5,
        "reverse-direction": true
    },

"wireplumber": {
    "format": "{icon}",
    "format-muted": "Ύγσ",
    "states": {
        "loud": 70,
        "optimal": 45
    },
    "on-click": "wpctl set-mute @DEFAULT_SINK@ toggle",
    "on-click-right": "flatpak run org.pipewire.Helvum",
    "on-click-middle": "flatpak run com.github.wwmm.easyeffects ",
    "max-volume": 100,
    "format-icons": ["ΎΑο", "ΎΑπ", "ΎΑρ"],
    "tooltip": true,
    "tooltip-format": "{node_name}  {volume}%"
  },

"custom/arch": {
      "format": "ΎΝΔ",
      "tooltip": false,
    },       

"custom/terminal": {
      "format": "ΎΤΚ",
      "tooltip": true,
      "tooltip-format": "Launch Terminal Emulator",
      "on-click": "$TERMINAL"
    },       

"custom/browser": {
      "format": "≤░Ψθ",
      "tooltip": true,
      "tooltip-format": "Launch Web Browser",
      "on-click": "$BROWSER"
    },       

"custom/launcher": {
      "format": "≤▒Υη",
      "tooltip": true,
      "tooltip-format": "Launch Application Launcher",
      "on-click": "fuzzel"
    },       

"custom/filemanager": {
      "format": "≤▒ηΛ",
      "tooltip": true,
      "tooltip-format": "Launch File Manager",
      "on-click": "$TERMINAL -T nnn $HOME/.local/bin/nwrap"
    },       

"custom/hide-tray": {
     "format": "ΎΒΥ",
     "format-alt-click": "click-left",
     "tooltip": true,
     "tooltip-format": "Expand tray"
},

    "custom/power": {
        "format" : "έΠ╗",
		"tooltip": false,
		"menu": "on-click",
		"menu-file": "$HOME/.config/waybar/power_menu.xml",
		"menu-actions": {
      "lock": "loginctl lock-session",
      "logout": "loginctl terminate-user '' ",
			"shutdown": "systemctl poweroff",
			"reboot": "systemctl reboot",
			"suspend": "systemctl suspend",
		},
},
}
